# ============================================
# LLM Provider Configuration
# ============================================

# Provider: ollama | openai | google_genai | anthropic
LLM_PROVIDER=ollama

# Model name (provider-specific)
# Ollama: llama3.1, llama3.2, mistral, codellama, etc.
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Google: gemini-2.0-flash-exp, gemini-pro, gemini-pro-vision
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
ORCHESTRATOR_MODEL=qwen3:32b
PLANNER_MODEL=qwen3:32b
EXECUTOR_MODEL=qwen3:32b
VALIDATOR_MODEL=qwen3:32b

# LLM parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=
LLM_STREAMING=false

# ============================================
# Provider-Specific API Keys
# ============================================

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google Gemini
GOOGLE_API_KEY=your_google_api_key

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================================
# Sketchfab 3D Models
# ============================================

# Sketchfab API Token
SKETCHFAB_TOKEN=

# Sketchfab API Base URL
SKETCHFAB_BASE_URL="https://api.sketchfab.com/v3"

# Local path to store downloaded 3D models
3D_MODELS_PATH=

# ============================================
# Unity Integration
# ============================================

# Path to the root of your Unity project (e.g., /path/to/MyUnityProject)
# The agent will write scripts to Assets/Scripts/SceneLogic.cs
UNITY_PROJECT_PATH=

# Specify the path to the scripts folder
UNITY_SCRIPTS_PATH=

# WebSocket Bridge (if used)
UNITY_WEBSOCKET_URI=
