# ============================================
# LLM Provider Configuration
# ============================================

# Provider: ollama | openai | google_genai | anthropic
LLM_PROVIDER=ollama

# Model name (provider-specific)
# Ollama: llama3.1, llama3.2, mistral, codellama, etc.
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Google: gemini-2.0-flash-exp, gemini-pro, gemini-pro-vision
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
LLM_MODEL=llama3.1

# LLM parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=
LLM_STREAMING=false

# ============================================
# Provider-Specific API Keys
# ============================================

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# ============================================
# Neo4j Knowledge Graph
# ============================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ============================================
# Sketchfab 3D Models
# ============================================

SKETCHFAB_TOKEN=your_sketchfab_api_token

# ============================================
# Unity Integration
# ============================================

# Path to the root of your Unity project (e.g., /path/to/MyUnityProject)
# The agent will write scripts to Assets/Scripts/SceneLogic.cs
UNITY_PROJECT_PATH=

# OR specific path to the scripts folder
UNITY_SCRIPTS_PATH=./generated/unity_scripts/

# WebSocket Bridge (if used)
UNITY_WEBSOCKET_URI=ws://localhost:8080

# ============================================
# LangSmith (Optional - for debugging/tracing)
# ============================================

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=eXRage
